{
  "name": "pr-typescript-checker",
  "version": "1.0.0",
  "description": "GitHub Action that type-checks only the files changed in a PR",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --minify",
    "compile": "tsc"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.1"
  },
  "keywords": [
    "github-actions",
    "typescript",
    "ci",
    "type-checking",
    "pull-request",
    "developer-tools",
    "devops"
  ]
}
